{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/auto-launch-sessions",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/autopilot-tick",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/cron/question-generation-jobs/run",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/house-games/tick",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/email-digests?kind=upcoming",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/email-digests?kind=weekly",
      "schedule": "15 14 * * 1"
    }
  ]
}
