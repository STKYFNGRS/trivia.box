# App (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Neon — https://console.neon.tech
DATABASE_URL=

# Ably — https://ably.com/dashboard
# Server publishes with ABLY_API_KEY; browser uses token from /api/ably/token
ABLY_API_KEY=

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Resend — https://resend.com (host invite emails from venues)
RESEND_API_KEY=
INVITES_FROM_EMAIL=noreply@yourdomain.com

# Optional: comma-separated Clerk user IDs for extra admin gate
ADMIN_CLERK_USER_IDS=
