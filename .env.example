# App (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Neon — https://console.neon.tech (Drizzle uses a small serverless Pool for transaction support)
DATABASE_URL=

# Ably — https://ably.com/dashboard
# Server publishes with ABLY_API_KEY; browser uses token from /api/ably/token
ABLY_API_KEY=

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Resend — https://resend.com (host invite emails from venues)
RESEND_API_KEY=
INVITES_FROM_EMAIL=noreply@yourdomain.com

# Optional: comma-separated Clerk user IDs for extra admin gate
ADMIN_CLERK_USER_IDS=

# Site admin (internal): comma-separated Clerk user IDs — first sign-in creates `site_admin` + linked `players` row
SITE_ADMIN_CLERK_USER_IDS=
# Dev only: with NODE_ENV!=production, set to 1 so site_admin skips Stripe for organizer APIs and can join games
SITE_ADMIN_DEV_BYPASS=

# Question LLM — Claude via the Anthropic Messages API
CLAUDE_API_KEY=
# Optional: override the default claude-sonnet-4-20250514
CLAUDE_MODEL=

# Optional only: for POST /api/cron/question-generation-jobs/run without a Clerk session (e.g. Vercel cron).
# Not required for local dev or when you use “Process up to 5 queued” in admin while signed in.
CRON_SECRET=

# --- House games (required for free :00/:30 house rounds) -----------------
# Id of the platform `accounts` row used as the host + venue for free
# house games. Without this set, the house-games cron falls back to the
# first `site_admin` account; if neither exists the cron is a silent no-op
# and `/play` will show no upcoming games. Set in production.
TRIVIA_BOX_HOUSE_ACCOUNT_ID=

# --- Ops foundation (all optional; fail open when unset) -------------------

# Sentry — https://sentry.io/settings/projects/
# DSN is the only var required to start collecting errors. The _AUTH_TOKEN +
# ORG + PROJECT trio is only needed at build time to upload source maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Optional override; defaults to NODE_ENV.
SENTRY_ENV=
NEXT_PUBLIC_SENTRY_ENV=

# Upstash Redis — https://console.upstash.com (used by lib/rateLimit.ts)
# When unset, rate limiting fails open (no-op) so local dev is unblocked.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostHog — https://posthog.com (product analytics + funnels)
# When NEXT_PUBLIC_POSTHOG_KEY is unset, every track() / identify() no-ops.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
